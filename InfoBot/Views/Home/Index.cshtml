@{
    ViewBag.Title = "Smart Info Chatbot (Offline)";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Smart Info Chatbot (Offline Mode)</title>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

    <style>
        body {
            font-family: Arial, sans-serif;
            margin: 0;
            background: #f4f6f9;
        }

        /* RIGHT EDGE HOVER ZONE */
        #edge-hover-zone {
            position: fixed;
            top: 0;
            right: 0;
            width: 12px;
            height: 100vh;
            z-index: 9997;
        }

        /* CHATBOT ICON */
        #chatbot-icon {
            position: fixed;
            bottom: 20px;
            right: -90px;
            width: 64px;
            height: 64px;
            background: linear-gradient(135deg, #28a745, #1e7e34);
            border-radius: 50%;
            cursor: pointer;
            box-shadow: 0 8px 20px rgba(0,0,0,0.4);
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 32px;
            font-weight: bold;
            transition: right 0.3s ease-in-out;
            z-index: 9999;
        }

        /* CHATBOT WINDOW */
        #chatbot {
            position: fixed;
            bottom: 100px;
            right: 20px;
            width: 500px;
            max-height: 580px;
            background: white;
            border-radius: 14px;
            box-shadow: 0 8px 30px rgba(0,0,0,0.4);
            display: none;
            flex-direction: column;
            z-index: 9998;
        }

        #chat-header {
            background: #28a745;
            color: white;
            padding: 14px;
            font-weight: bold;
            text-align: center;
            border-radius: 14px 14px 0 0;
            position: relative;
        }

        #close {
            position: absolute;
            right: 10px;
            top: 8px;
            background: red;
            color: white;
            border: none;
            padding: 4px 8px;
            cursor: pointer;
            border-radius: 4px;
        }

        #chat-body {
            padding: 12px;
            overflow-y: auto;
            flex: 1;
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        table, th, td {
            border: 1px solid #ccc;
        }

        th {
            background: #28a745;
            color: white;
            padding: 8px;
        }

        td {
            padding: 8px;
            cursor: pointer;
        }

        tr:hover {
            background: #eafaf0;
        }

        /* ✨ GLOSSY GLASS EFFECT (PRESERVED) */
        .clickable {
            color: #0b5ed7;
            cursor: pointer;
            padding: 4px 6px;
            border-radius: 6px;
            background: linear-gradient( rgba(255,255,255,0.6), rgba(255,255,255,0.15) );
            backdrop-filter: blur(6px);
            box-shadow: inset 0 1px 1px rgba(255,255,255,0.6), 0 2px 6px rgba(0,0,0,0.15);
            transition: all 0.25s ease;
        }

            .clickable:hover {
                background: linear-gradient( rgba(255,255,255,0.85), rgba(255,255,255,0.35) );
                box-shadow: inset 0 1px 1px rgba(255,255,255,0.8), 0 4px 10px rgba(0,0,0,0.25);
                transform: translateY(-1px);
            }

        #chat-footer {
            padding: 10px;
            border-top: 1px solid #ccc;
            display: flex;
            justify-content: center;
            gap: 12px;
        }

        #send-mail, #back-btn {
            padding: 8px 18px;
            border: none;
            border-radius: 8px;
            cursor: pointer;
            font-weight: bold;
            display: none;
        }

        #send-mail {
            background: #28a745;
            color: white;
        }

        #back-btn {
            background: #6c757d;
            color: white;
        }
    </style>
</head>

<body>

    <div id="edge-hover-zone"></div>
    <div id="chatbot-icon">C</div>

    <div id="chatbot">
        <div id="chat-header">
            Smart Info Bot
            <button id="close">X</button>
        </div>

        <div id="chat-body">
            <table>
                <thead>
                    <tr>
                        <th>Error Code</th>
                        <th>Description</th>
                    </tr>
                </thead>
                <tbody id="error-table-body"></tbody>
            </table>
        </div>

        <div id="chat-footer">
            <button id="back-btn">← Back</button>
            <button id="send-mail">Send Mail</button>
        </div>
    </div>

    <script>
    let selectedError = null;
    let initialHtml = null;

    $('#edge-hover-zone').mouseenter(() => {
        $('#chatbot-icon').css('right', '20px');
    });

    $(document).mousemove(e => {
        if (!$('#chatbot').is(':visible') && e.clientX < window.innerWidth - 120) {
            $('#chatbot-icon').css('right', '-90px');
        }
    });

    $('#chatbot-icon').click(() => {
        $('#chatbot').css('display', 'flex');
        if (!initialHtml) initialHtml = $('#chat-body').html();
        loadErrorCodes();
    });

    $('#close').click(() => {
        stopVideo();
        restoreErrorList();
        $('#chatbot').hide();
        $('#chatbot-icon').css('right', '-90px');
    });

    function loadErrorCodes() {
        $.get('@Url.Action("GetErrorCodes","Home")', data => {
            $('#error-table-body').empty();
            $.each(data, (_, item) => {
                const row = $('<tr>').data('item', item);
                row.append(`<td class="clickable">${item.error_code}</td>`);
                row.append(`<td class="clickable">${item.description}</td>`);
                $('#error-table-body').append(row);
            });
        });
    }

    $(document).on('click', '#error-table-body td', function () {
        const item = $(this).parent().data('item');
        selectedError = item;

        let html = `
            <div style="text-align:center">
                <strong>${item.error_code}</strong><br>
                ${item.description}<br><br>
        `;

        if (item.video_path) {
            const path = '/' + item.video_path.replace(/\\/g, '/');
            html += `
                <video id="solution-video" width="400" height="250" controls>
                    <source src="${path}" type="video/mp4">
                </video>`;
        } else {
            html += '<em>No video available</em>';
        }

        html += '</div>';

        $('#chat-body').html(html);
        $('#send-mail, #back-btn').show();
    });

    $('#back-btn').click(() => {
        stopVideo();
        restoreErrorList();
    });

    function restoreErrorList() {
        $('#chat-body').html(initialHtml);
        $('#send-mail, #back-btn').hide();
        selectedError = null;
        loadErrorCodes();
    }

    function stopVideo() {
        const video = document.getElementById('solution-video');
        if (video) {
            video.pause();
            video.src = '';
            video.load();
        }
    }

    $('#send-mail').click(() => {
        if (!selectedError) return;
        $.post('/Home/SendEmail', {
            errorCode: selectedError.error_code,
            description: selectedError.description
        }, res => alert(res));
    });
    </script>

</body>
</html>